APP_NAME=MACUIN
APP_ENV=local
APP_KEY=base64:dGhpcyBpcyBhIHRlc3Qga2V5IGZvciBtYWN1aW4=
APP_DEBUG=true
APP_URL=http://localhost:8080

# La API es quien accede a la BD, Laravel solo consume la API
API_URL=http://api:8000/v1

# SQLite mínimo para que Laravel arranque (sesiones, caché)
DB_CONNECTION=sqlite
DB_DATABASE=/tmp/laravel.sqlite

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
CACHE_STORE=file
